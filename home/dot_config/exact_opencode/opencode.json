{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.3-codex",
  "share": "disabled",
  "agent": {
    "plan": {
      "model": "github-copilot/gpt-5.3-codex"
    },
    "build": {
      "model": "github-copilot/gpt-5.3-codex"
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git diff": "allow",
      "cat": "allow",
      "ls": "allow",
    },
    "lsp": "allow",
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**"
    ]
  },
  "command": {
    "git-commit": {
      "template": "git add all changes && git commit A good commit message with conventional commits style && git push",
      "description": "Generates a git commit message based on the changes made",
      "agent": "build"
    },
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "playwright-mcp@latest"
      ],
      "enabled": false
    }
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ]
}
