# vim: syntax=toml
# Mise configuration
# https://mise.jdx.dev/configuration.html

[tools]
chezmoi = "2.70.4"
rust = "1.96.0"
ruby = "3.4.1"
node = "24.13.1"
pnpm = "11.4.0"
yarn = "1.22.19"
python = "3.13.11"
awscli = "2.13.18"
bun = "1.3.9"
java = "temurin-21.0.11+10.0.LTS"
go = "1.26.3"
lua = "5.1"
deno = "2.8.1"
just = "1.51.0"
zig = "0.16.0"
{{ if not .computer.isWork -}}
php = "8.5.3"
{{- end }}

[settings]
# Enable legacy version file support (.tool-versions, .node-version, etc.)
legacy_version_file = true
ruby.default_packages_file = "~/.config/ruby/default-gems"

# Verbose output
verbose = false
