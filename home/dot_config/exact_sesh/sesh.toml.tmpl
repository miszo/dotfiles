#:schema https://github.com/joshmedeski/sesh/raw/main/sesh.schema.json
# vim: syntax=toml

[default_session]
preview_command = "eza -l --color always -a -s type --icons --no-permissions {}"

[[session]]
name = "config"
path = "~/.config"
startup_command = "tmux rename-window editor && nvim"
windows = ["shell"]

[[session]]
name = "chezmoi"
path = "~/.local/share/chezmoi"
startup_command = "tmux rename-window editor && nvim"
windows = ["shell"]

[[session]]
name = "miszo-readme"
path = "~/dev/miszo/miszo"
startup_command = "tmux rename-window editor && nvim"
windows = ["shell"]

[[session]]
name = "package-info"
path = "~/dev/miszo/package-info.nvim"
startup_command = "tmux rename-window editor && nvim"
windows = ["shell"]

[[window]]
name = "shell"

{{ if .computer.isWork -}}
{{ onepasswordRead "op://Employee/sesh/notesPlain" .op.work.accountCode -}}
{{- end -}}
